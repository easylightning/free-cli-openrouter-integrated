{
  "name": "openrouter-free-cli",
  "version": "1.0.0",
  "description": "OpenRouter API uyumlu, tamamen ücretsiz modelleri listeleyen terminal AI chat uygulaması",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openrouter-free": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@inquirer/prompts": "7.5.2",
    "chalk": "5.4.1",
    "cli-table3": "0.6.5",
    "commander": "13.1.0",
    "env-paths": "3.0.0",
    "undici": "7.10.0",
    "zod": "3.25.28"
  },
  "devDependencies": {
    "@types/node": "22.15.21",
    "@vitest/coverage-v8": "3.2.2",
    "eslint": "9.27.0",
    "prettier": "3.5.3",
    "rimraf": "6.0.1",
    "tsup": "8.5.0",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
